@using FunMasters.Shared.DTOs

<EditForm Model="Model" method="post" OnValidSubmit="OnValidSubmit" FormName="@FormName">
    <DataAnnotationsValidator/>
    <fieldset class="fieldset">
        <legend class="fieldset-legend">Score: @Model.Score @Model.GetRatingLabel()</legend>
        <input type="range" @bind="Model.Score" @bind:event="oninput" class="range w-full" min="0.1" max="10" step="0.1"/>
    </fieldset>
    <fieldset>
        <legend class="fieldset-legend">Comment</legend>
        <InputTextArea @bind-Value="Model.Comment"
                       id="@("rate-comment-" + FormName)"
                       class="textarea min-h-24 w-full" placeholder="Optional"/>
    </fieldset>
    <div class="form-floating mb-3">
        <label for="@("rate-comment-" + FormName)" class="form-label"></label>
    </div>
    <fieldset class="fieldset">
        <legend class="fieldset-legend">Hours Played</legend>
        <input type="number" @bind="Model.PlaytimeHours" @bind:event="oninput"
               class="input w-full" min="0" step="0.1" placeholder="Optional"/>
    </fieldset>
    <div>
        <button type="submit" class="btn btn-lg btn-primary w-full mt-3" disabled="@Model.IsSubmitting">
            @if (Model.IsSubmitting)
            {
                <span class="loading loading-spinner"></span>
            }
            @SubmitLabel
        </button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired] public ReviewFormModel Model { get; set; } = null!;
    [Parameter, EditorRequired] public string FormName { get; set; } = null!;
    [Parameter] public string SubmitLabel { get; set; } = "Rate";
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }
}
