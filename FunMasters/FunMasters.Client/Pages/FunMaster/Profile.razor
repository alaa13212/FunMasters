@page "/funmaster/{UserId:guid}"
@using FunMasters.Client.Components
@using System.Security.Claims
@inject IAccountApiService AccountApi
@inject NavigationManager Nav

<PageTitle>@(_profile?.UserName ?? "Fun Master")</PageTitle>

<div class="m-5">
    @if (_loading)
    {
        <p>Loading...</p>
    }
    else if (_profile == null)
    {
        <h3>Fun Master not found</h3>
    }
    else
    {
        <div class="card bg-base-200 shadow-md max-w-[800px] m-auto">
            <div class="card-body">
                <div class="flex items-center gap-4">
                    <img src="@_profile.AvatarUrl" class="w-20 h-20 mask mask-squircle"/>
                    <div>
                        <h2 class="text-3xl text-primary">@_profile.UserName</h2>
                        <div class="flex gap-1 items-center mt-1">
                            @switch (_profile.CouncilStatus)
                            {
                                case "Excommunicated":
                                    <span class="badge badge-error">Excommunicated</span>
                                    break;
                                case "Executed":
                                    <span class="badge badge-ghost">Executed</span>
                                    break;
                                case "Candidate":
                                    <span class="badge badge-warning">Candidate</span>
                                    break;
                                case "Shadow":
                                    <span class="badge badge-neutral">Shadow</span>
                                    break;
                            }
                        </div>
                    </div>
                </div>

                @if (_profile.Badges.Any())
                {
                    <div class="flex flex-wrap gap-3 mt-3">
                        @foreach (var badge in _profile.Badges)
                        {
                            <div class="flex items-center gap-2 bg-base-300 rounded-lg px-3 py-2">
                                @if (!string.IsNullOrEmpty(badge.ImageUrl))
                                {
                                    <img src="@badge.ImageUrl" alt="@badge.Name" class="w-12 h-12 hover:scale-400 transition-all object-contain"/>
                                }
                                <div>
                                    <div class="font-bold text-sm">@badge.Name</div>
                                    @if (!string.IsNullOrEmpty(badge.Description))
                                    {
                                        <div class="text-xs opacity-70">@badge.Description</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_profile.Bio))
                {
                    <div class="mt-4">
                        <h4 class="text-lg font-bold mb-1">Bio</h4>
                        <p class="whitespace-pre-wrap">@_profile.Bio</p>
                    </div>
                }
            </div>
        </div>

        @if (_profile.SuggestedGames.Any())
        {
            <div class="max-w-[800px] m-auto mt-6">
                <h3 class="text-2xl mb-3">Suggested Games</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @foreach (var game in _profile.SuggestedGames)
                    {
                        <a href="/game/@game.Id" class="card bg-base-200 shadow-sm card-hover">
                            <div class="card-body flex-row items-center gap-3 p-3">
                                @if (!string.IsNullOrEmpty(game.CoverImageUrl))
                                {
                                    <img src="@game.CoverImageUrl" alt="@game.Title" class="w-16 h-16 object-cover rounded"/>
                                }
                                <div>
                                    <h4 class="font-bold">@game.Title</h4>
                                    <span class="text-sm opacity-70">@game.Status</span>
                                    @if (game.AverageRating.HasValue)
                                    {
                                        <span class="text-sm ms-2 text-primary">@(game.AverageRating.Value.ToString("0.#"))/10</span>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

        @if (_profile.ReviewedGames.Any())
        {
            <div class="max-w-[800px] m-auto mt-6">
                <h3 class="text-2xl mb-3">Reviewed Games</h3>
                <div class="space-y-2">
                    @foreach (var review in _profile.ReviewedGames)
                    {
                        <a href="/game/@review.SuggestionId" class="card bg-base-200 shadow-sm card-hover block">
                            <div class="card-body flex-row items-center gap-3 p-3">
                                @if (!string.IsNullOrEmpty(review.CoverImageUrl))
                                {
                                    <img src="@review.CoverImageUrl" alt="@review.Title" class="w-16 h-16 object-cover rounded flex-shrink-0"/>
                                }
                                <div class="min-w-0">
                                    <h4 class="font-bold">@review.Title</h4>
                                    <div class="flex items-center gap-2">
                                        <span class="text-primary font-bold">@((review.Score / 10m).ToString("0.#"))/10</span>
                                        <span class="text-sm opacity-70">@review.RatingLabel</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <p class="text-sm opacity-70 mt-1 line-clamp-2">@review.Comment</p>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

        <div class="max-w-[800px] m-auto mt-6">
            <h3 class="text-2xl mb-3">Comments</h3>

            <AuthorizeView>
                <Authorized>
                    @if (_profile.CouncilStatus != "Executed")
                    {
                        <div class="mb-4">
                            <div class="flex gap-2">
                                <input type="text" class="input input-bordered flex-1" placeholder="Leave a comment..."
                                       @bind="_newComment" maxlength="1000" @bind:event="oninput"
                                       @onkeydown="OnCommentKeydown"/>
                                <button class="btn btn-primary" @onclick="SubmitComment"
                                        disabled="@(string.IsNullOrWhiteSpace(_newComment) || _submittingComment)">
                                    @if (_submittingComment)
                                    {
                                        <span class="loading loading-spinner loading-sm"></span>
                                    }
                                    Post
                                </button>
                            </div>
                        </div>
                    }
                </Authorized>
            </AuthorizeView>

            @if (_profile.Comments.Any())
            {
                <div class="space-y-3">
                    @foreach (var comment in _profile.Comments)
                    {
                        <div class="card bg-base-200 shadow-sm">
                            <div class="card-body p-3">
                                <div class="flex items-center gap-2">
                                    <a href="/funmaster/@comment.AuthorId">
                                        <img src="@comment.AuthorAvatarUrl" class="w-8 h-8 mask mask-squircle"/>
                                    </a>
                                    <a href="/funmaster/@comment.AuthorId" class="font-bold hover:underline">@comment.AuthorUserName</a><UserBadgeDisplay Badges="@comment.AuthorBadges" UserId="@comment.AuthorId" SizePx="14"/>
                                    <span class="text-sm opacity-50">@comment.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                    @if (comment.AuthorId == _myId || _isAdmin)
                                    {
                                        <button class="btn btn-ghost btn-xs ml-auto" @onclick="() => DeleteComment(comment.Id)">x</button>
                                    }
                                </div>
                                <p class="mt-1 whitespace-pre-wrap">@comment.Text</p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="opacity-70">No comments yet.</p>
            }
        </div>
    }
</div>

@code {
    [Parameter] public Guid UserId { get; set; }

    [PersistentState] public FunMasterProfileDto? _profile { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool _loading = true;
    private string _newComment = "";
    private bool _submittingComment;
    private Guid? _myId;
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profile ??= await AccountApi.GetFunMasterProfileAsync(UserId);

            if (AuthenticationStateTask != null)
            {
                var authState = await AuthenticationStateTask;
                if (authState.User.Identity?.IsAuthenticated == true)
                {
                    _myId = Guid.TryParse(authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : null;
                    _isAdmin = authState.User.IsInRole("Admin");
                }
            }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task SubmitComment()
    {
        if (string.IsNullOrWhiteSpace(_newComment)) return;
        _submittingComment = true;
        try
        {
            var result = await AccountApi.AddFunMasterCommentAsync(UserId, new CreateFunMasterCommentRequest { Text = _newComment });
            if (result.Success)
            {
                _newComment = "";
                _profile = await AccountApi.GetFunMasterProfileAsync(UserId);
            }
        }
        catch { }
        finally { _submittingComment = false; }
    }

    private async Task OnCommentKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SubmitComment();
        }
    }

    private async Task DeleteComment(Guid commentId)
    {
        try
        {
            var result = await AccountApi.DeleteFunMasterCommentAsync(commentId);
            if (result.Success)
                _profile = await AccountApi.GetFunMasterProfileAsync(UserId);
        }
        catch { }
    }
}
